{
  "name": "lord-funion/purple-parlor",
  "description": "Private, dependency-light PHP platform for The Purple Parlor.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "ext-json": "*",
    "ext-mbstring": "*",
    "ext-pdo": "*",
    "ext-openssl": "*",
    "phpmailer/phpmailer": "^6.9"
  },
  "suggest": {
    "ext-sodium": "Preferred for encrypting administrator TOTP secrets",
    "ext-intl": "Improved Unicode normalization",
    "ext-curl": "Preferred HTTP transport for PayPal and Square",
    "ext-pdo_mysql": "Required in production",
    "ext-pdo_sqlite": "Used by the automated test suite"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "PurpleParlor\\Games\\": "app/Games/",
      "Database\\Seeds\\": "database/seeds/"
    },
    "files": [
      "app/Support/helpers.php"
    ]
  },
  "config": {
    "allow-plugins": {},
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "test": "php bin/test.php",
    "migrate": "php bin/migrate.php",
    "seed": "php bin/seed.php",
    "check": "php bin/system-check.php"
  }
}

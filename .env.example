# Copy to .env, keep it outside the public document root when possible, and never commit it.
APP_NAME="The Purple Parlor"
APP_BRAND="Lord Funion"
APP_CREATOR_NAME="Lord Funion"
APP_TAGLINE="A cozy, play-money social casino and casino-game arcade."
APP_SUPPORT_EMAIL=support@lordfunion.dev
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
APP_TIMEZONE=America/New_York
APP_KEY=
APP_MINIMUM_AGE=18
APP_LEGAL_POLICY_VERSION=1
APP_INDEXING_ENABLED=false
APP_ASSET_PATH=/assets
APP_UPLOAD_MAX_BYTES=5242880

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=purple_parlor
DB_USERNAME=
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_OPTIONS=

SESSION_COOKIE=purple_parlor_session
SESSION_LIFETIME_MINUTES=120
SESSION_SECURE=false
SESSION_SAMESITE=Lax
SESSION_DOMAIN=
SESSION_PATH=/
SESSION_STORAGE_PATH=
REMEMBER_ME_DAYS=30
PRIVILEGED_SESSION_MINUTES=15

# smtp, mail (cPanel local MTA), or sendmail
MAIL_DRIVER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@lordfunion.dev
MAIL_FROM_NAME="The Purple Parlor"
MAIL_MAX_ATTEMPTS=5

# All four live gates must have the exact safe values before live checkout is possible.
PAYMENTS_ENABLED=false
PAYMENT_MODE=sandbox
PAYMENT_PROVIDER=demo
ADULT_OWNER_CONFIRMED=false
LIVE_PAYMENT_ACTIVATION_LOCK=true
PAYMENT_CURRENCY=USD
PAYMENT_WEBHOOK_RETENTION_DAYS=90
SUBSCRIPTION_GRACE_DAYS=7
COZY_CLUB_DAILY_COINS=1000
COZY_CLUB_PLUS_DAILY_COINS=2500

PAYPAL_ENABLED=false
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PRODUCT_ID=
PAYPAL_COZY_MONTHLY_PLAN_ID=
PAYPAL_COZY_ANNUAL_PLAN_ID=
PAYPAL_PLUS_MONTHLY_PLAN_ID=
PAYPAL_PLUS_ANNUAL_PLAN_ID=

SQUARE_ENABLED=false
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_API_VERSION=2026-05-20
SQUARE_WEBHOOK_URL=
SQUARE_COZY_MONTHLY_PLAN_VARIATION_ID=
SQUARE_COZY_ANNUAL_PLAN_VARIATION_ID=
SQUARE_PLUS_MONTHLY_PLAN_VARIATION_ID=
SQUARE_PLUS_ANNUAL_PLAN_VARIATION_ID=

ADS_ENABLED=false
ADS_PROVIDER=placeholder
ADSENSE_CLIENT_ID=

LOG_LEVEL=debug
LOG_MAX_FILES=14
BACKUP_PATH=
BACKUP_RETENTION_DAYS=30
CRON_SECRET=
CRON_BACKUP_HOUR_UTC=5

# Temporary 64-hex-character token used only by /install. Clear it after setup.
INSTALL_TOKEN=

# Optional local-only seed account. Ignored in production; choose a unique 12+ character password.
DEV_SEED_EMAIL=
DEV_SEED_USERNAME=
DEV_SEED_PASSWORD=
